# Определение состояний для ConversationHandler (опционально, но рекомендуется)
WAITING_FOR_LYRICS = 1

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработчик команды /start"""
    keyboard = [
        ["Найти музыку по тексту"],
        ["Скачать музыку"]
    ]
    
    reply_markup = ReplyKeyboardMarkup(keyboard, resize_keyboard=True, one_time_keyboard=True)
    
    await update.message.reply_text(
        "Добро пожаловать! Выберите действие:",
        reply_markup=reply_markup
    )
    
    # Сбрасываем любые предыдущие состояния
    if 'state' in context.user_data:
        context.user_data.pop('state')

async def handle_buttons(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработчик нажатий на кнопки клавиатуры"""
    text = update.message.text
    chat_id = update.effective_chat.id
    
    if text == "Найти музыку по тексту":
        await update.message.reply_text(
            "Пожалуйста, отправьте отрывок текста песни (несколько строк), и я попробую найти её."
        )
        # Сохраняем состояние в context.user_data (лучше чем глобальная переменная)
        context.user_data['state'] = 'waiting_for_lyrics'
        
    elif text == "Скачать музыку":
        await update.message.reply_text(
            "Функция скачивания музыки в разработке. Пока вы можете найти песни по тексту."
        )
        
    elif context.user_data.get('state') == 'waiting_for_lyrics':
        # Пользователь прислал текст для поиска
        lyrics_snippet = text.strip()
        
        if len(lyrics_snippet) < 5:
            await update.message.reply_text("Пожалуйста, отправьте более длинный отрывок (минимум 5 символов).")
            return
            
        await update.message.reply_text(f"Ищу песню по тексту: '{lyrics_snippet[:50]}...'")
        
        # Проверяем, инициализирован ли Genius API
        if genius_api is None:
            await update.message.reply_text("Сервис поиска временно недоступен. Попробуйте позже.")
            context.user_data.pop('state', None)
            return
        
        # Выполняем поиск через Genius API
        try:
            search_results = genius_api.search_songs(lyrics_snippet, per_page=5)
            
            if search_results and 'hits' in search_results and search_results['hits']:
                # Формируем список найденных песен
                response_text = "Найденные песни:\n\n"
                
                for i, hit in enumerate(search_results['hits'][:5], 1):  # Показываем первые 5 результатов
                    result = hit['result']
                    title = result.get('title', 'Неизвестно')
                    artist = result.get('primary_artist', {}).get('name', 'Неизвестный исполнитель')
                    url = result.get('url', '#')
                    
                    response_text += f"{i}. **{title}** - {artist}\n"
                    response_text += f"   [Ссылка]({url})\n\n"
                
                # Добавляем инструкцию
                response_text += "Если нужной песни нет в списке, попробуйте отправить другой отрывок."
                
                await update.message.reply_text(response_text, parse_mode='Markdown')
                
            else:
                await update.message.reply_text(
                    "Не удалось найти песню по этому отрывку.\n"
                    "Попробуйте:\n"
                    "• Отправить другой отрывок\n"
                    "• Проверить правильность написания\n"
                    "• Использовать более уникальные слова из песни"
                )
                
        except Exception as e:
            logger.error(f"Ошибка при поиске в Genius API: {e}")
            await update.message.reply_text(
                "Произошла ошибка при поиске. Пожалуйста, попробуйте позже."
            )
        
        # Сбрасываем состояние
        context.user_data.pop('state', None)
        
    else:
        # Если сообщение не соответствует ни одному состоянию
        await update.message.reply_text(
            "Выберите действие с помощью кнопок ниже:",
            reply_markup=ReplyKeyboardMarkup(
                [["Найти музыку по тексту"], ["Скачать музыку"]],
                resize_keyboard=True,
                one_time_keyboard=True
            )
        )

async def cancel(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Отмена текущего действия"""
    context.user_data.pop('state', None)
    await update.message.reply_text(
        "Действие отменено. Выберите новое действие:",
        reply_markup=ReplyKeyboardMarkup(
            [["Найти музыку по тексту"], ["Скачать музыку"]],
            resize_keyboard=True
        )
    )
    
